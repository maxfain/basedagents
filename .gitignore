node_modules/
dist/
.wrangler/
.dev.vars
*.db
*.sqlite
.DS_Store
coverage/
*.tsbuildinfo
# Local data files (DB dumps, exports)
/data/

# Environment files — use .env.example as template
.env
.env.local
.env.production
.env.staging
.env.*.local

# Keypairs — NEVER commit private keys
*-keypair.json
*.keypair.json

# Wrangler backups
wrangler.toml
wrangler.toml.bak
# …but packages/api/wrangler.toml IS the committed Worker config (no secrets —
# STRIPE_SECRET_KEY etc. are wrangler secrets, not in this file). Must be tracked
# or CI has no Worker config to deploy.
!packages/api/wrangler.toml
.claude/
packages/python/**/__pycache__/
packages/python/*.egg-info/
packages/python/dist/
packages/python/.venv/
packages/python/build/
.mcpregistry_*

# Playwright E2E artifacts
packages/console/test-results/
packages/console/playwright-report/
packages/api/.e2e-data/
packages/api/.repro-data/
