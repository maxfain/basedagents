# Agent Registry Configuration

# Server
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_PATH=./data/registry.db

# Proof-of-Work difficulty (number of leading zero bits)
POW_DIFFICULTY=20

# Challenge expiry in seconds
CHALLENGE_TTL_SECONDS=300

# Auth: max clock skew in seconds
AUTH_MAX_CLOCK_SKEW=60

# Bootstrap mode: registry verifies agents directly until this many are active
BOOTSTRAP_THRESHOLD=100
