{
  "name": "agent-registry-api",
  "main": "packages/api/src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],

  // D1 Database binding (Cloudflare's edge SQLite)
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agent-registry",
      "database_id": "e8173f0d-7d4f-44c7-8abb-8871a8b56627",
      "migrations_dir": "packages/api/migrations"
    }
  ],

  "vars": {
    "POW_DIFFICULTY": "20",
    "CHALLENGE_TTL_SECONDS": "300",
    "AUTH_MAX_CLOCK_SKEW": "60",
    "BOOTSTRAP_THRESHOLD": "100"
  },

  // Pages static output (frontend)
  "pages_build_output_dir": "packages/web/dist",

  // Custom domain route
  "routes": [
    { "pattern": "api.whythings.com", "zone_name": "whythings.com" }
  ]
}
