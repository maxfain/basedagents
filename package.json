{
  "name": "basedagents",
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/sdk",
    "packages/web",
    "packages/console",
    "packages/mcp",
    "packages/keyring",
    "packages/recipes",
    "packages/github-action"
  ],
  "scripts": {
    "build": "npm run build:dist --workspace=packages/keyring && npm run build --workspaces",
    "typecheck": "tsc --build",
    "lint": "eslint . && node scripts/lint-ui-words.mjs",
    "lint:words": "node scripts/lint-ui-words.mjs",
    "//keyring-dist": "console + api import @basedagents/keyring/{crypto,util}, which resolve to keyring/dist — build it before any workspace that depends on it (dist is gitignored, so a fresh clone has none).",
    "pretest": "npm run build:dist --workspace=packages/keyring",
    "test": "npm run test --workspaces --if-present",
    "smoke": "node scripts/smoke-clean.mjs",
    "test:e2e": "npm run test:e2e --workspace=packages/console",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "undici": "^6.22.0"
  }
}
