{
  "schema": "basedagents-recipe/v1",
  "provider": "example-dashboard",
  "version": "1.0.0",
  "display_name": "Example Dashboard (template)",
  "transport": "browser",
  "sandbox": {
    "domains": ["app.example.com"],
    "vault_access": "write-only"
  },
  "scopes": ["read-only", "read-write"],
  "procedures": {
    "mint": {
      "transport": "browser",
      "steps": [
        { "action": "navigate", "target": "https://app.example.com/settings/api-keys", "note": "Open the API keys page in your own logged-in session" },
        { "action": "click", "target": "text=Create new key" },
        { "action": "fill", "target": "input[name=key_name]", "value": "ba/{{agent}}/{{grant_id}}", "note": "Name the key so it is identifiable in the provider dashboard" },
        { "action": "select", "target": "select[name=scope]", "value": "{{scope}}" },
        { "action": "click", "target": "text=Generate key" }
      ]
    },
    "capture": {
      "transport": "browser",
      "steps": [
        { "action": "read_value", "target": "code[data-testid=new-key-value]", "value": "capture:secret", "note": "Read the freshly generated value straight into the vault; it is never shown to the human" }
      ]
    },
    "burn": {
      "transport": "browser",
      "steps": [
        { "action": "navigate", "target": "https://app.example.com/settings/api-keys" },
        { "action": "click", "target": "tr:has-text('ba/{{agent}}/{{grant_id}}') button[aria-label=Revoke]" },
        { "action": "click", "target": "text=Confirm revoke" }
      ]
    }
  }
}
