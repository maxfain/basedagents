{
  "name": "@basedagents/recipes",
  "version": "0.1.0",
  "description": "Open, signed, sandboxed Provisioner recipes for BasedAgents Keyring — mint, capture, rotate, and burn provider credentials",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": "./schema/recipe.schema.json"
  },
  "files": [
    "dist",
    "schema",
    "recipes",
    "README.md",
    "LICENSE",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build:dist",
    "test": "vitest run"
  },
  "keywords": [
    "basedagents",
    "keyring",
    "provisioner",
    "recipes",
    "credentials",
    "secrets",
    "agents"
  ],
  "author": "BasedAgents",
  "license": "Apache-2.0",
  "homepage": "https://basedagents.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxfain/basedagents.git",
    "directory": "packages/recipes"
  },
  "bugs": {
    "url": "https://github.com/maxfain/basedagents/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
