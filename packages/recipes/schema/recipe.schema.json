{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://basedagents.ai/schema/recipe.schema.json",
  "title": "BasedAgents Provisioner Recipe",
  "description": "A signed, sandboxed recipe that teaches Keyring how to mint / capture / rotate / burn a credential at one provider. See KEYRING_SPEC.md §6.",
  "type": "object",
  "required": ["schema", "provider", "version", "display_name", "transport", "sandbox", "scopes", "procedures"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "basedagents-recipe/v1" },
    "provider": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
    "display_name": { "type": "string", "minLength": 1 },
    "transport": { "enum": ["api", "browser"] },
    "sandbox": {
      "type": "object",
      "required": ["domains", "vault_access"],
      "additionalProperties": false,
      "properties": {
        "domains": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "vault_access": { "const": "write-only" }
      }
    },
    "scopes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "procedures": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "mint": { "$ref": "#/definitions/procedure" },
        "capture": { "$ref": "#/definitions/procedure" },
        "rotate": { "$ref": "#/definitions/procedure" },
        "burn": { "$ref": "#/definitions/procedure" }
      },
      "required": ["mint", "burn"]
    },
    "signature": {
      "type": "object",
      "required": ["author_pubkey", "signature"],
      "additionalProperties": false,
      "properties": {
        "author_pubkey": { "type": "string" },
        "signature": { "type": "string" }
      }
    }
  },
  "definitions": {
    "procedure": {
      "type": "object",
      "required": ["transport", "steps"],
      "additionalProperties": false,
      "properties": {
        "transport": { "enum": ["api", "browser"] },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["action"],
            "additionalProperties": false,
            "properties": {
              "action": { "type": "string", "minLength": 1 },
              "target": { "type": "string" },
              "value": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
