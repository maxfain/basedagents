{
  "name": "@basedagents/keyring",
  "version": "0.5.15",
  "description": "Scoped, revocable credentials bound to cryptographic agent identities — local-first encrypted vault, identity-bound grants, short-lived leases, signed access log",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto.js",
      "types": "./dist/crypto.d.ts"
    },
    "./util": {
      "import": "./dist/util.js",
      "types": "./dist/util.d.ts"
    }
  },
  "bin": {
    "based": "./bin/based.mjs",
    "keyring": "./bin/based.mjs",
    "basedagents-keyring-mcp": "./bin/keyring-mcp.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/bundle-mcp-vendor.mjs",
    "prepare": "npm run build:dist",
    "prepublishOnly": "npm run build:dist && npm run smoke:mcp",
    "smoke:mcp": "node scripts/mcp-smoke.mjs",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "agents",
    "secrets",
    "credentials",
    "vault",
    "keyring",
    "mcp",
    "ed25519",
    "basedagents"
  ],
  "author": "BasedAgents",
  "license": "Apache-2.0",
  "homepage": "https://basedagents.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxfain/basedagents.git",
    "directory": "packages/keyring"
  },
  "bugs": {
    "url": "https://github.com/maxfain/basedagents/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "esbuild": "^0.27.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.0",
    "@noble/ed25519": "^2.2.0",
    "@noble/hashes": "^1.7.0",
    "playwright-core": "^1.61.1",
    "undici": "^6.21.0",
    "zod": "^3.25.0"
  }
}
