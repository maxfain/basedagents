{
  "name": "basedagents",
  "version": "0.3.1",
  "description": "SDK for the BasedAgents identity and reputation registry — register AI agents, sign requests, search the registry, and submit verifications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "basedagents": "./bin/basedagents.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "identity",
    "reputation",
    "registry",
    "ed25519",
    "llm",
    "agentic",
    "trust",
    "basedagents"
  ],
  "author": "BasedAgents <hello@basedagents.ai>",
  "license": "Apache-2.0",
  "homepage": "https://basedagents.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxfain/basedagents.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/maxfain/basedagents/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.0",
    "@noble/hashes": "^1.7.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
